# ============================================================
# FrameReview V2 — 环境变量模板
# 复制此文件为 .env 后填写实际值
# ============================================================
#
# 部署方式选择（取消对应部分的注释）：
#
#   A) Render 托管（推荐）：使用 Render 的 PostgreSQL + Redis
#   B) 本地 Docker 开发：使用 docker-compose.yml 中的服务
#   C) 自行部署（Linux 服务器）：手动安装 PostgreSQL + Redis
#

# ── 通用 ──────────────────────────────────────────────────
APP_NAME="FrameReview"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── 数据库 ─────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=framereview
DB_USERNAME=framereview
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=redis
CACHE_STORE=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── 对象存储 ───────────────────────────────────────────────
# Render: 使用 Render PostgreSQL 内置的连接字符串
# 本地/Docker: 使用 MinIO（见下方）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=framereview
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── MinIO（本地开发用）───────────────────────────────────
# 生产环境请替换为真实对象存储（S3 兼容）
MINIO_ENABLED=true
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_PATH_STYLE=true
MINIO_ROOT_USER=framereview
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=framereview

# ── 媒体存储路径 ─────────────────────────────────────────
# Render: /var/opt/media (容器内持久路径)
# 本地 Docker: /nas/media (宿主机 NAS 挂载)
MEDIA_ROOT=/var/opt/media

# ── 上传限制 ──────────────────────────────────────────────
PHP_UPLOAD_MAX_FILESIZE=10G
PHP_POST_MAX_SIZE=10G

# ── 邮件 ──────────────────────────────────────────────────
MAIL_MAILER=log

# ── 媒体处理 Worker ───────────────────────────────────────
MEDIA_WORKER_ENABLED=true
MEDIA_WORKER_CONCURRENCY=2
FFPROBE_TIMEOUT=60
THUMBNAIL_COUNT=10
SPRITE_STRIP_COLUMNS=10

# ── 分享安全 ─────────────────────────────────────────────
SHARE_TOKEN_BYTES=32
SHARE_LINK_EXPIRY_DAYS=30

# ── Meilisearch（全文搜索）───────────────────────────────
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=changeme_search_key
