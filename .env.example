# ============================================================
# FrameReview V2 — 环境变量模板
# 复制此文件为 .env 后填写实际值
# ============================================================

APP_NAME="FrameReview"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── 数据库 ────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=framereview
DB_USERNAME=framereview
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=redis
CACHE_STORE=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── MinIO / 对象存储 ──────────────────────────────────────
AWS_ACCESS_KEY_ID=framereview
AWS_SECRET_ACCESS_KEY=changeme
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=framereview
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── NAS 媒体存储路径 ─────────────────────────────────────
# 挂载到容器内 /nas/media，存放原始媒体文件
MEDIA_ROOT=/nas/media

# ── 上传限制 ──────────────────────────────────────────────
PHP_UPLOAD_MAX_FILESIZE=10G
PHP_POST_MAX_SIZE=10G

# ── 邮件（发送通知用）────────────────────────────────────
MAIL_MAILER=log

# ── 媒体处理 Worker ──────────────────────────────────────
MEDIA_WORKER_ENABLED=true
MEDIA_WORKER_CONCURRENCY=2
FFPROBE_TIMEOUT=60
THUMBNAIL_COUNT=10
SPRITE_STRIP_COLUMNS=10

# ── 分享安全 ─────────────────────────────────────────────
SHARE_TOKEN_BYTES=32
SHARE_LINK_EXPIRY_DAYS=30
