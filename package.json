{
  "name": "framereview",
  "version": "2.0.0",
  "description": "FrameReview V2 - Video Review Platform (Node.js API + media-worker)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:client": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "worker:start": "npm --prefix media-worker run start",
    "worker:dev": "npm --prefix media-worker run dev",
    "check:runtime": "powershell -ExecutionPolicy Bypass -File scripts/check-runtime.ps1",
    "build:prisma": "npx prisma@5.22.0 generate",
    "db:push": "npx prisma@5.22.0 db push",
    "db:migrate": "npx prisma@5.22.0 migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma@5.22.0 studio",
    "reset:local": "node scripts/reset-local.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.25.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
